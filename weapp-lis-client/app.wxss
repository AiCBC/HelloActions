page { background-color: #f6f7f9; }
.form { padding: 12px; }
.label { color: #666; font-size: 12px; margin-bottom: 6px; }
.input { background: #fff; padding: 8px 10px; border: 1px solid #e5e5e5; border-radius: 6px; }
.btn { margin-top: 10px; }
.card { background: #fff; border-radius: 10px; padding: 12px; margin: 12px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
pre { white-space: pre-wrap; word-break: break-all; font-size: 12px; }